// Prisma schema for FleetFlow — fully local PostgreSQL auth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum UserRole {
  manager
  dispatcher
  safety
  finance
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum DriverDutyStatus {
  ON_DUTY
  OFF_DUTY
  SUSPENDED
}

// ─────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────

/// Local users stored in PostgreSQL — no Supabase dependency.
model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(dispatcher)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Driver {
  id              String          @id @default(uuid())
  fullName        String
  phone           String?
  licenseNo       String?         @unique
  licenseExpiry   DateTime?
  dutyStatus      DriverDutyStatus @default(ON_DUTY)
  violations      Int             @default(0)
  lateTrips       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  trips           Trip[]
  expenses        Expense[]

  @@map("drivers")
}

model Vehicle {
  id           String        @id @default(uuid())
  plateNumber  String        @unique
  make         String
  model        String
  year         Int
  type         String        @default("Truck")
  status       VehicleStatus @default(AVAILABLE)
  fuelLevel    Float?        @default(100)
  mileage      Int?          @default(0)
  maxPayload   Float?        // Max capacity in tons
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  trips        Trip[]
  serviceLogs  ServiceLog[]
  expenses     Expense[]

  @@map("vehicles")
}

model Trip {
  id                 String     @id @default(uuid())
  tripNumber         Int        @default(autoincrement())
  status             TripStatus @default(DRAFT)
  origin             String
  destination        String
  cargo              String?
  cargoWeight        Float?     // kg
  estimatedFuelCost  Float?     // currency
  vehicleId          String?
  driverId           String?
  vehicle            Vehicle?   @relation(fields: [vehicleId], references: [id])
  driver             Driver?    @relation(fields: [driverId], references: [id])
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  expense            Expense?

  @@map("trips")
}

enum ServiceLogStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

model ServiceLog {
  id          String           @id @default(uuid())
  logNumber   Int              @default(autoincrement())
  vehicleId   String
  vehicle     Vehicle          @relation(fields: [vehicleId], references: [id])
  issue       String
  cost        Float?
  status      ServiceLogStatus @default(NEW)
  serviceDate DateTime         @default(now())
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("service_logs")
}

model Expense {
  id          String   @id @default(uuid())
  tripId      String   @unique
  trip        Trip     @relation(fields: [tripId], references: [id])
  driverId    String?
  driver      Driver?  @relation(fields: [driverId], references: [id])
  vehicleId   String?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  fuelLiters  Float?
  fuelCost    Float    @default(0)
  miscExpense Float    @default(0)
  totalCost   Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

