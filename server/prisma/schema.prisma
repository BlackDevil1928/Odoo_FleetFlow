// Prisma schema for FleetFlow — fully local PostgreSQL auth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum UserRole {
  manager
  dispatcher
  safety
  finance
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────

/// Local users stored in PostgreSQL — no Supabase dependency.
model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(dispatcher)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Driver {
  id        String   @id @default(uuid())
  fullName  String
  phone     String?
  licenseNo String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trips     Trip[]

  @@map("drivers")
}

model Vehicle {
  id           String        @id @default(uuid())
  plateNumber  String        @unique
  make         String
  model        String
  year         Int
  type         String        @default("Truck")
  status       VehicleStatus @default(AVAILABLE)
  fuelLevel    Float?        @default(100)
  mileage      Int?          @default(0)
  maxPayload   Float?        // Max capacity in tons
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  trips        Trip[]

  @@map("vehicles")
}

model Trip {
  id                 String     @id @default(uuid())
  tripNumber         Int        @default(autoincrement())
  status             TripStatus @default(DRAFT)
  origin             String
  destination        String
  cargo              String?
  cargoWeight        Float?     // kg
  estimatedFuelCost  Float?     // currency
  vehicleId          String?
  driverId           String?
  vehicle            Vehicle?   @relation(fields: [vehicleId], references: [id])
  driver             Driver?    @relation(fields: [driverId], references: [id])
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("trips")
}
